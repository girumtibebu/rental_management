# ─────────────────────────────────────────────────────────────────
#  Copy this file to ".env" and adjust the values before running
#  docker compose up --build
#  (the .env file is listed in .gitignore so secrets stay local)
# ─────────────────────────────────────────────────────────────────

# ERPNext image tag – must match the Frappe/ERPNext version you
# want to run.  Available tags: v14, v15, v16, latest
ERPNEXT_VERSION=v15

# Frappe site name.  Use a hostname that resolves to 127.0.0.1
# (plain "localhost" suffixes work out of the box).
SITE_NAME=mysite.localhost

# Port that Windows Chrome will connect to:  http://localhost:8085
HTTP_PORT=8085

# MariaDB root password (used internally by the stack)
DB_PASSWORD=admin

# Frappe "Administrator" user password – use this to log in
ADMIN_PASSWORD=admin
